# Supabase (실서비스 백엔드) — 대시보드 > Project Settings > API 에서 복사
# 실제 값은 .env 파일에 넣고 커밋하지 말 것 (.gitignore에 .env 포함)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Sentry 에러 모니터링(웹) — sentry.io > Project > Settings > Client Keys(DSN) 에서 복사
# 미설정 시 모니터링 비활성(앱은 정상 동작). 설정 후 재배포하면 활성화.
EXPO_PUBLIC_SENTRY_DSN=
