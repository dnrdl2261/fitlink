{
  "name": "followfit",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "cross-env BASE_URL=/fitlink expo export --platform web",
    "deploy": "npm run build:web && node -e \"require('fs').copyFileSync('dist/index.html','dist/404.html')\" && type nul > dist\\.gitignore && type nul > dist\\.nojekyll && gh-pages -d dist --dotfiles"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-vector-icons/material-design-icons": "^13.0.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-paper": "^5.15.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "cross-env": "^10.1.0",
    "gh-pages": "^6.3.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
